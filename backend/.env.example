# ─── TrafficOS Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── PostgreSQL (optional — simulation runs in-memory without this) ─────────────
# Set USE_DB=true to enable persistent logging of metrics and heatmap data
USE_DB=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=robot_traffic
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Simulation Defaults ────────────────────────────────────────────────────────
DEFAULT_ROBOT_COUNT=10
SIM_TICK_RATE_MS=100          # How fast the simulation runs (milliseconds per tick)
WS_BROADCAST_EVERY_N_TICKS=2  # Broadcast state every N ticks (lower = smoother UI, more CPU)
DEADLOCK_CHECK_EVERY_N=15     # Check for deadlocks every N ticks
CONGESTION_DECAY_EVERY_N=8    # Decay congestion score every N ticks

# ── Map Layout ─────────────────────────────────────────────────────────────────
MAP_COLS=7
MAP_ROWS=5
MAP_SPACING_PX=108            # Gap between nodes in pixels

# ── Robot Behavior ─────────────────────────────────────────────────────────────
MAX_WAIT_BEFORE_REPLAN=4.0    # Seconds a robot waits before replanning around a blocked lane
BATTERY_DRAIN_RATE=0.008      # Battery % lost per unit of speed per second
LOW_BATTERY_THRESHOLD=20      # Battery % below which speed is halved
EMERGENCY_STOP_AT=0           # Battery % at which robot emergency-stops

# ── Safety Multipliers (applied on top of lane max_speed) ─────────────────────
SAFETY_CRITICAL_MULT=0.3
SAFETY_HIGH_MULT=0.5
SAFETY_LOW_MULT=1.2

# ── Lane Type Multipliers ──────────────────────────────────────────────────────
LANE_HUMAN_ZONE_MULT=0.4
LANE_NARROW_MULT=0.7
LANE_INTERSECTION_MULT=0.6

# ── A* Pathfinding Cost Weights ───────────────────────────────────────────────
ASTAR_CONGESTION_WEIGHT=3.0   # How much congestion increases lane cost
ASTAR_RESERVED_PENALTY=5.0    # Cost multiplier if lane is reserved by another robot
ASTAR_FULL_PENALTY=4.0        # Cost multiplier if lane is at full capacity
ASTAR_HUMAN_ZONE_MULT=2.0     # Extra cost multiplier for human zones
ASTAR_NARROW_MULT=1.5         # Extra cost multiplier for narrow lanes

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000